#code for digital watch in python
import tkinter as tk
import time

# Create main window
root = tk.Tk()
root.title("Digital Watch")
root.geometry("400x200")
root.resizable(False, False)
root.configure(bg="black")

# Time label
label = tk.Label(
    root,
    font=("Arial", 50, "bold"),
    background="black",
    foreground="cyan"
)
label.pack(anchor="center", pady=40)

# Function to update time every second
def update_time():
    current_time = time.strftime("%H:%M:%S")
    label.config(text=current_time)
    label.after(1000, update_time)  # Refresh every 1 second

# Start the clock
update_time()

# Run the app
root.mainloop()
